# Hermetic backend environment.
# Copy to backend/.env and fill in the values.

# Supabase project credentials.
# Find them in: Supabase dashboard → Project settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# IMPORTANT: this is the *service_role* key (NOT the anon key).
# It bypasses Row-Level-Security and must never be sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Optional: GitHub token for higher API rate limits when fetching
# Hermes Agent commits/releases. Create one at:
#   https://github.com/settings/tokens
GITHUB_TOKEN=
